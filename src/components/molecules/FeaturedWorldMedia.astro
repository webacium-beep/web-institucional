---
interface Props {
  fallbackText?: string;
  videoSrc?: string;
}

const { fallbackText = 'Video de la sección world pendiente de definición', videoSrc } = Astro.props;

// const videoSrc = '/videos/world.mp4';
---

{videoSrc && (
  <div class="w-full lg:w-auto flex-1 self-stretch min-h-[280px] lg:min-h-[420px] overflow-hidden">
    {fallbackText && <span class="sr-only">{fallbackText}</span>}
    <video
      class="h-full w-auto object-cover"
      autoplay
      muted
      loop
      playsinline
      src={videoSrc}
    />
  </div>
)}
