---
import video from '../../assets/TERCERA_PRUEBA_DEL_ANILLO.mp4';
---
<section 
  class="relative w-full overflow-hidden bg-black flex items-center justify-center" 
  aria-label="Banner principal"
  style="min-height: calc(100dvh - var(--header-height, 166px));"
>
  <!-- Preparado para recibir el video de fondo -->
  <video src={video} class="absolute inset-0 w-full h-full object-cover opacity-50" autoplay loop muted playsinline></video>
  
  <div class="relative z-10 w-full h-full flex items-center justify-center">
    <!-- Contenido que vaya por encima del video. Se deja este texto provisorio para que sepas que el banner está renderizando correctamente -->
    <!-- <p class="text-white/30 text-sm tracking-[0.2em] uppercase font-avenir">Banner (Video Placeholder)</p> -->
  </div>
</section>
