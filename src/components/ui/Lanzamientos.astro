---
import { useTranslations } from '../../i18n/utils';
import { sanityClient } from '../../lib/sanity/client';
import { LANZAMIENTOS_QUERY } from '../../lib/sanity/queries';
import { buildLanzamientosSanityState } from '../../lib/sanity/lanzamientos.utils';
import type { LanzamientosPost } from '../../lib/sanity/types';

const t = useTranslations(Astro.currentLocale);
const lanzamientosPost = await sanityClient.fetch<LanzamientosPost | null>(LANZAMIENTOS_QUERY);
const state = buildLanzamientosSanityState(lanzamientosPost);
---

<section class="w-full max-h-[600px] bg-white px-0 py-20 text-black md:px-0">
  <div class="flex h-full">
     <div class="overflow-hidden  min-w-[50%]">
      {state.hasImage ? (
        <img
          src={state.image?.url}
          alt={state.image?.alt ?? ''}
          class="h-full max-h-[474px] w-full object-contain"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="flex min-h-[420px] w-full items-center justify-center bg-neutral-200">
          <span class="text-sm uppercase tracking-[0.3em] text-neutral-500">
            {t('lanzamientos.badgePrefix')}
            <span class="font-bold">{t('lanzamientos.badgeHighlight')}</span>
          </span>
        </div>
      )}
    </div>

    <!-- TEXTO DERECHA -->
<div class="flex flex-col gap-3 px-10 py-12 min-w-[50%]">
  <h2 class="text-3xl leading-tight tracking-tight">
    <span class="font-light uppercase">
      {t('lanzamientos.badgePrefix')}
      <span class="font-bold">{t('lanzamientos.badgeHighlight')}</span>
    </span>
    <br />
    <span class="text-4xl font-bold uppercase tracking-widest">{t('lanzamientos.title')}</span>
  </h2>

  <div class="border-l-2 border-black pl-3 mt-1">
    <p class="text-sm font-light text-black">{t('lanzamiento.modelo')}</p>
    <p class="text-sm font-light text-black">{t('lanzamientos.description')}</p>
  </div>
  <a
    href="/lanzamientos"
    class="mt-3 w-fit border border-black px-5 py-2 text-[10px] uppercase tracking-[0.2em] text-black transition-colors duration-200 hover:bg-black hover:text-white">
    {t('lanzamientos.cta')}
  </a>
</div>

     </div>
</section>
