---
import { Image } from "astro:assets";
import logoParaLaNav from "../../assets/logos/logo-para-la-nav.png";
import LanguageSelector from "../islands/LanguageSelector";
import { normalizeLocale, useTranslations } from "../../i18n/utils";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const safeLocale = normalizeLocale(locale);
const t = useTranslations(safeLocale);
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 font-avenir w-full bg-black text-white">
  {/* Top row: 3 columns */}
  <div class="flex justify-between items-center px-6 pt-8 pb-7">
    {/* Left: CTA Button */}
    <div class="flex-1 flex items-center">
      <a
        href="#"
        class="cta-button border border-[#8F8F8F] text-[#9B9B9B] bg-transparent px-5 py-2 text-[13px] tracking-[0.2em] font-[500] transition-colors duration-200 hover:bg-[#999999] hover:text-white hover:font-[800]"
      >
        {t('nav.cta')}
      </a>
    </div>

    {/* Center: Logo */}
    <div class="flex-1 flex justify-center items-center">
      <Image
        src={logoParaLaNav}
        alt="ACIUM Logo"
        height={50}
        class="object-contain w-auto"
      />
    </div>

    {/* Right: Language Selector */}
    <div class="flex-1 flex justify-end items-center text-[#9B9B9B]">
      <LanguageSelector client:load currentLocale={safeLocale} selectorLabel={t('selector.label')} />
    </div>
  </div>

  {/* Bottom row: Navigation links */}
  <div class="border-b border-[#6E6E6E]">
    <nav class="mx-auto flex max-w-[1180px] justify-between items-center gap-8 px-8 md:px-12 pt-6 pb-5">
      <a
        href="#"
        data-text={t('nav.about')}
        class="nav-link relative text-[13px] tracking-[0.18em] text-[#9B9B9B] font-[300] hover:text-white hover:font-[800] transition-none"
      >
        {t('nav.about')}
        <span class="nav-ghost" aria-hidden="true">{t('nav.about')}</span>
      </a>
      <a
        href="#"
        data-text={t('nav.world')}
        class="nav-link relative text-[13px] tracking-[0.18em] text-[#9B9B9B] font-[300] hover:text-white hover:font-[800] transition-none"
      >
        {t('nav.world')}
        <span class="nav-ghost" aria-hidden="true">{t('nav.world')}</span>
      </a>
      <a
        href="#"
        data-text={t('nav.franchise')}
        class="nav-link relative text-[13px] tracking-[0.18em] text-[#9B9B9B] font-[300] hover:text-white hover:font-[800] transition-none"
      >
        {t('nav.franchise')}
        <span class="nav-ghost" aria-hidden="true">{t('nav.franchise')}</span>
      </a>
      <a
        href="#"
        data-text={t('nav.newsroom')}
        class="nav-link relative text-[13px] tracking-[0.18em] text-[#9B9B9B] font-[300] hover:text-white hover:font-[800] transition-none"
      >
        {t('nav.newsroom')}
        <span class="nav-ghost" aria-hidden="true">{t('nav.newsroom')}</span>
      </a>
    </nav>
  </div>
</header>

<style>
  /*
    Layout shift prevention technique:
    Each nav link contains a hidden <span> (nav-ghost) that holds the same text
    at font-weight 800. This pre-reserves the space for the bold width, so when
    the visible text transitions to bold on hover, no reflow / layout shift occurs.
  */
  .nav-link {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
  }

  .nav-ghost {
    font-weight: 800;
    height: 0;
    overflow: hidden;
    visibility: hidden;
    display: block;
    /* Ensures the ghost does NOT interfere with line-height rendering */
    pointer-events: none;
    user-select: none;
  }
</style>

<script>
  const syncHeaderHeight = () => {
    const header = document.getElementById("site-header");
    if (!header) return;

    document.documentElement.style.setProperty("--header-height", `${header.offsetHeight}px`);
  };

  syncHeaderHeight();
  window.addEventListener("load", syncHeaderHeight);
  window.addEventListener("resize", syncHeaderHeight);
</script>
