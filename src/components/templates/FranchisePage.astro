---
import PageLayout from '../../layouts/PageLayout.astro';
import type { Locales } from '../../i18n/ui';
import { usePageTranslations } from '../../i18n/utils';
import { franchisePage } from '../../i18n/franchise-page';

interface Props {
  lang: Locales;
}

const { lang } = Astro.props;
const t = usePageTranslations(lang, franchisePage);

const benefits = [
  'franchisePage.benefits.item1',
  'franchisePage.benefits.item2',
  'franchisePage.benefits.item3',
] as const;

const requirements = [
  'franchisePage.requirements.item1',
  'franchisePage.requirements.item2',
  'franchisePage.requirements.item3',
] as const;
---

<PageLayout lang={lang}>
  <article class="mx-auto flex w-full max-w-6xl flex-col gap-12 px-6 py-12 text-black md:gap-16 md:px-10 md:py-16 lg:px-14">
    <header class="space-y-6 border-b border-neutral-200 pb-10 text-center md:space-y-7 md:pb-12">
      <p class="text-[12px] font-[700] uppercase tracking-[0.34em] text-neutral-500">
        {t('franchisePage.hero.eyebrow')}
      </p>
      <h1 class="mx-auto max-w-4xl text-[30px] font-black uppercase leading-[1.02] tracking-[-0.03em] md:text-[40px]">
        {t('franchisePage.title')}
      </h1>
      <p class="mx-auto max-w-3xl text-[22px] font-medium leading-[1.25] text-black md:text-[28px]">
        {t('franchisePage.hero.title')}
      </p>
      <p class="mx-auto max-w-3xl text-[18px] font-light leading-[1.8] text-black/80">
        {t('franchisePage.hero.description')}
      </p>
    </header>

    <section aria-labelledby="franchise-intro-title" class="mx-auto flex w-full max-w-4xl flex-col gap-5 text-left">
      <h2 id="franchise-intro-title" class="text-[22px] font-medium leading-[1.15] text-black">
        {t('franchisePage.intro.title')}
      </h2>
      <p class="text-[18px] font-light leading-[1.8] text-black/80">
        {t('franchisePage.intro.description')}
      </p>
    </section>

    <section aria-labelledby="franchise-foundation-title" class="grid gap-8 lg:grid-cols-2 lg:gap-10">
      <h2 id="franchise-foundation-title" class="sr-only">
        {t('franchisePage.title')}
      </h2>

      <section class="rounded-[28px] border border-neutral-200 bg-neutral-50 p-8 text-left">
        <h3 class="text-[20px] font-black uppercase tracking-[0.08em] text-black">
          {t('franchisePage.benefits.title')}
        </h3>
        <ul class="mt-6 flex flex-col gap-4 text-[18px] font-light leading-[1.7] text-black/80">
          {benefits.map((item) => (
            <li class="flex items-start gap-3">
              <span aria-hidden="true" class="mt-[0.7em] h-2 w-2 shrink-0 rounded-full bg-black"></span>
              <span>{t(item)}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="rounded-[28px] border border-neutral-200 bg-white p-8 text-left">
        <h3 class="text-[20px] font-black uppercase tracking-[0.08em] text-black">
          {t('franchisePage.requirements.title')}
        </h3>
        <ul class="mt-6 flex flex-col gap-4 text-[18px] font-light leading-[1.7] text-black/80">
          {requirements.map((item) => (
            <li class="flex items-start gap-3">
              <span aria-hidden="true" class="mt-[0.7em] h-2 w-2 shrink-0 rounded-full bg-black"></span>
              <span>{t(item)}</span>
            </li>
          ))}
        </ul>
      </section>
    </section>

    <section aria-labelledby="franchise-support-title" class="mx-auto flex w-full max-w-4xl flex-col gap-5 rounded-[32px] bg-black px-8 py-10 text-white md:px-10">
      <h2 id="franchise-support-title" class="text-[22px] font-medium leading-[1.15]">
        {t('franchisePage.support.title')}
      </h2>
      <p class="text-[18px] font-light leading-[1.8] text-white/80">
        {t('franchisePage.support.description')}
      </p>
    </section>

    <section aria-labelledby="franchise-cta-title" class="mx-auto flex w-full max-w-4xl flex-col items-center gap-5 rounded-[32px] border border-neutral-200 px-8 py-12 text-center md:px-10">
      <h2 id="franchise-cta-title" class="text-[24px] font-black leading-[1.15] text-black md:text-[28px]">
        {t('franchisePage.cta.title')}
      </h2>
      <p class="max-w-2xl text-[18px] font-light leading-[1.8] text-black/80">
        {t('franchisePage.cta.description')}
      </p>
      <a
        href="mailto:aciummilano@acium.group?subject=Franchise%20Opportunity"
        class="inline-flex items-center border border-black bg-black px-6 py-3 text-center text-[11px] font-[700] uppercase tracking-[0.32em] text-white transition-colors duration-200 hover:bg-white hover:text-black"
      >
        {t('franchisePage.cta.button')}
      </a>
    </section>
  </article>
</PageLayout>
