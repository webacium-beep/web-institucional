---
import PageLayout from '../../layouts/PageLayout.astro';
import type { Locales } from '../../i18n/ui';
import { usePageTranslations } from '../../i18n/utils';
import { worldPage } from '../../i18n/world-page';

interface Props {
  lang: Locales;
}

const { lang } = Astro.props;
const t = usePageTranslations(lang, worldPage);
---

<PageLayout lang={lang}>
  <article class="mx-auto flex w-full max-w-6xl flex-col gap-12 px-6 pt-12 md:px-10 md:pt-16">
    <header class="flex flex-col gap-4">
      <p class="text-[14px] font-medium uppercase tracking-[0.24em] text-black/60">ACIUM</p>
      <h1 class="text-[32px] font-black uppercase tracking-[0.12em] text-black lg:text-[40px]">
        {t('worldPage.title')}
      </h1>
    </header>
  </article>
</PageLayout>
