---
import PageLayout from "../../layouts/PageLayout.astro";
import type { Locales } from "../../i18n/ui";
import { usePageTranslations } from "../../i18n/utils";
import { aboutPage } from "../../i18n/about-page";
import kioskoAboutUsSectionOne from '../../assets/aboutuspage/kioskoaboutussectionone.svg';
import imagenEternidad from '../../assets/aboutuspage/imagenEternidad.svg';
import imagenesDeLosDosDijes from '../../assets/aboutuspage/imagenesdelosdosdijes.svg';
import imagenEmocion from '../../assets/aboutuspage/imagenemocion.svg';
import imagenNuestroLegado from '../../assets/aboutuspage/imagennuestrolegado.svg';
import imagenVersatilidad from '../../assets/aboutuspage/imagenversatilidad.svg';
import iconExperiencia from '../../assets/aboutuspage/iconexpperiencia.svg';
import iconPortafolio from '../../assets/aboutuspage/iconPortafolio.svg';
import iconProducto from '../../assets/aboutuspage/iconProducto.svg';
import iconSistema from '../../assets/aboutuspage/iconSistema.svg';
import kioskoSeccionFinal from '../../assets/aboutuspage/kioskoseccionfinal.svg';

interface Props {
  lang: Locales;
}

const { lang } = Astro.props;
const t = usePageTranslations(lang, aboutPage);
const kioskoAboutUsSectionOneSrc = typeof kioskoAboutUsSectionOne === 'string'
  ? kioskoAboutUsSectionOne
  : kioskoAboutUsSectionOne.src;
const heroDescription = t('aboutPage.hero.description');
const [heroDescriptionBeforeBrand, heroDescriptionAfterBrand = ''] = heroDescription.split('ACIUM');
const imagenEternidadSrc = typeof imagenEternidad === 'string' ? imagenEternidad : imagenEternidad.src;
const imagenesDeLosDosDijesSrc = typeof imagenesDeLosDosDijes === 'string' ? imagenesDeLosDosDijes : imagenesDeLosDosDijes.src;
const imagenEmocionSrc = typeof imagenEmocion === 'string' ? imagenEmocion : imagenEmocion.src;
const imagenNuestroLegadoSrc = typeof imagenNuestroLegado === 'string' ? imagenNuestroLegado : imagenNuestroLegado.src;
const imagenVersatilidadSrc = typeof imagenVersatilidad === 'string' ? imagenVersatilidad : imagenVersatilidad.src;
const iconExperienciaSrc = typeof iconExperiencia === 'string' ? iconExperiencia : iconExperiencia.src;
const iconPortafolioSrc = typeof iconPortafolio === 'string' ? iconPortafolio : iconPortafolio.src;
const iconProductoSrc = typeof iconProducto === 'string' ? iconProducto : iconProducto.src;
const iconSistemaSrc = typeof iconSistema === 'string' ? iconSistema : iconSistema.src;
const kioskoSeccionFinalSrc = typeof kioskoSeccionFinal === 'string' ? kioskoSeccionFinal : kioskoSeccionFinal.src;
const legacyParagraph3 = t('aboutPage.legacy.paragraph3');
const [legacyParagraph3BeforeBrand, legacyParagraph3AfterBrand = ''] = legacyParagraph3.split('ACIUM');
const dnaCards = [
  {
    imageSrc: imagenEternidadSrc,
    imageAlt: 'Joya ACIUM Eternidad',
    title: 'aboutPage.dna.values.eternity.title',
    description: 'aboutPage.dna.values.eternity.description',
  },
  {
    imageSrc: imagenEmocionSrc,
    imageAlt: 'Joya ACIUM Emoción',
    title: 'aboutPage.dna.values.emotion.title',
    description: 'aboutPage.dna.values.emotion.description',
  },
  {
    imageSrc: imagenVersatilidadSrc,
    imageAlt: 'Joya ACIUM Versatilidad',
    title: 'aboutPage.dna.values.versatility.title',
    description: 'aboutPage.dna.values.versatility.description',
  },
] as const;

const integratedModelFeatures = [
  {
    iconSrc: iconProductoSrc,
    iconAlt: 'Ícono de producto emocional',
    label: 'aboutPage.integratedModel.features.product',
  },
  {
    iconSrc: iconExperienciaSrc,
    iconAlt: 'Ícono de experiencia en punto de venta',
    label: 'aboutPage.integratedModel.features.pointOfSale',
  },
  {
    iconSrc: iconPortafolioSrc,
    iconAlt: 'Ícono de portafolio adaptable',
    label: 'aboutPage.integratedModel.features.portfolio',
  },
  {
    iconSrc: iconSistemaSrc,
    iconAlt: 'Ícono de sistema optimizado para retail',
    label: 'aboutPage.integratedModel.features.retail',
  },
] as const;
---

<PageLayout lang={lang}>
  <article class="mx-auto flex w-full max-w-6xl flex-col gap-16 px-6 pt-12 md:gap-24 md:px-10 md:pt-16">
    <header class="flex justify-center">
      <p class="text-[30px] font-black uppercase tracking-[0.2em] text-black">{t('aboutPage.heroTitle')}</p>
    </header>

    <section aria-labelledby="about-hero-title" class="grid items-center gap-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)] lg:gap-14">
      <div class="flex justify-center lg:justify-start">
        <img
          src={kioskoAboutUsSectionOneSrc}
          alt="ACIUM display kiosk"
          class="h-auto w-full max-w-[520px] object-contain lg:max-w-[560px]"
        />
      </div>

      <div class="space-y-6 lg:space-y-7">
        <h1
          id="about-hero-title"
          class="max-w-[420px] text-[32px] font-black leading-[1.1] tracking-[-0.02em] text-black lg:text-[35px]"
        >
          {t('aboutPage.hero.title')}
        </h1>

        <button
          type="button"
          class="inline-flex h-[45px] w-auto cursor-pointer items-center border border-neutral-300 bg-white px-4 text-left text-[16px] font-medium leading-none text-black transition-colors duration-300 hover:bg-black hover:text-white"
        >
          {t('aboutPage.hero.eyebrow')}
        </button>

        <p class="max-w-[440px] text-[18px] font-light leading-[1.55] text-black/85">
          {heroDescriptionBeforeBrand}
          <span class="text-[18px] font-medium tracking-[0.22em] text-black">A C I U M</span>
          {heroDescriptionAfterBrand}
        </p>
      </div>
    </section>

    <section aria-labelledby="about-dna-title" class="grid gap-10 lg:grid-cols-[minmax(0,220px)_1fr] lg:items-start lg:gap-12">
      <div class="space-y-2 text-center lg:w-[260px] lg:pt-14">
        <p class="w-full text-center text-[34px] font-black uppercase leading-none tracking-[-0.03em] text-black lg:text-[36px]">
          {t('aboutPage.dna.titleLine1')}
        </p>
        <h2 id="about-dna-title" class="w-full text-center text-[66px] font-black uppercase leading-[0.9] tracking-[0.18em] text-black lg:text-[72px]">
          {t('aboutPage.dna.titleLine2')}
        </h2>
      </div>

      <ul class="grid gap-8 md:grid-cols-3 md:gap-6 lg:gap-8" aria-label={t('aboutPage.dna.title')}>
        {dnaCards.map((card) => (
          <li class="flex flex-col items-center text-center">
            <div class="flex h-[250px] w-full max-w-[255px] items-center justify-center bg-white px-5 py-5">
              <img src={card.imageSrc} alt={card.imageAlt} class="h-auto max-h-full w-full object-contain" />
            </div>

            <h3 class="mt-5 text-[22px] font-medium uppercase leading-none text-black">{t(card.title)}</h3>
            <p class="mt-4 max-w-[210px] text-[18px] font-light leading-[1.35] text-black/85">{t(card.description)}</p>
          </li>
        ))}
      </ul>
    </section>

    <section aria-labelledby="about-legacy-title" class="space-y-10">
      <div class="mx-auto h-px w-[64px] bg-neutral-300"></div>

      <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:gap-14">
        <div class="space-y-6 lg:max-w-[420px]">
          <div class="space-y-4">
            <h2 id="about-legacy-title" class="text-[36px] font-black uppercase leading-none text-black">
              {t('aboutPage.legacy.title')}
            </h2>
            <p class="inline-flex h-[30px] w-auto cursor-pointer items-center border border-neutral-300 bg-white px-3 text-[14px] font-medium leading-none text-black transition-colors duration-300 hover:bg-black hover:text-white">
              {t('aboutPage.legacy.eyebrow')}
            </p>
          </div>

          <div class="space-y-4 text-[18px] font-light leading-[1.55] text-black/85">
            <p>{t('aboutPage.legacy.paragraph1')}</p>
            <p>{t('aboutPage.legacy.paragraph2')}</p>
            <p>
              {legacyParagraph3BeforeBrand}
              <span class="text-[18px] font-medium tracking-[0.22em] text-black">A C I U M</span>
              {legacyParagraph3AfterBrand}
            </p>
          </div>
        </div>

        <div class="flex justify-center lg:justify-end">
          <img
            src={imagenNuestroLegadoSrc}
            alt="Dije corazón ACIUM con retrato grabado"
            class="h-auto w-full max-w-[440px] object-contain lg:max-w-[500px]"
          />
        </div>
      </div>

      <div class="mx-auto h-px w-[64px] bg-neutral-300"></div>
    </section>

    <section aria-labelledby="about-integrated-model-title" class="grid gap-10 lg:grid-cols-[minmax(0,260px)_1fr] lg:items-start lg:gap-14">
      <div class="space-y-4 text-center">
        <h2 id="about-integrated-model-title" class="text-center text-3xl font-semibold md:text-4xl">
          {t('aboutPage.integratedModel.title')}
        </h2>
        <p class="mx-auto max-w-[260px] text-center text-[18px] font-light leading-[1.35] text-black/85">{t('aboutPage.integratedModel.description')}</p>
      </div>

      <ul class="grid gap-x-10 gap-y-12 sm:grid-cols-2" aria-label={t('aboutPage.integratedModel.title')}>
        {integratedModelFeatures.map((feature) => (
          <li class="flex items-start gap-5">
            <img src={feature.iconSrc} alt={feature.iconAlt} class="mt-1 h-[34px] w-[34px] object-contain opacity-70" />
            <p class="max-w-[180px] text-[18px] font-light leading-[1.35] text-black/85">{t(feature.label)}</p>
          </li>
        ))}
      </ul>
    </section>

    <div class="relative left-1/2 right-1/2 ml-[-50vw] mr-[-50vw] h-[575px] w-screen overflow-x-clip">
      <div class="relative h-full overflow-visible">
        <section aria-labelledby="about-final-cta-title" class="absolute inset-x-0 bottom-0 h-[458px] w-full bg-neutral-100">
          <div class="relative flex h-full items-center justify-center px-6">
          <div class="absolute left-0 top-[-117px] h-[498px] w-[530px]">
            <img
              src={kioskoSeccionFinalSrc}
              alt="Kiosco ACIUM de la sección final"
              class="h-full w-full object-contain"
            />
          </div>

          <div class="relative z-10 flex max-w-[520px] flex-col items-center justify-center gap-8 text-center">
            <h2 id="about-final-cta-title" class="text-[32px] font-black leading-[1.2] text-black lg:text-[36px]">
              <span class="block">{t('aboutPage.finalCta.titleLine1')}</span>
              <span class="mt-2 block">{t('aboutPage.finalCta.titleLine2')}</span>
            </h2>

            <button
              type="button"
              class="inline-flex h-[45px] w-auto cursor-pointer items-center border border-neutral-500 bg-white px-5 text-[14px] font-medium uppercase tracking-[0.12em] text-black transition-colors duration-300 hover:bg-black hover:text-white"
            >
              {t('aboutPage.finalCta.label')}
            </button>
          </div>

          <div class="absolute right-0 top-0 flex h-full items-start justify-end overflow-visible pr-[60px]">
            <div class="relative top-[-54px] w-full max-w-[360px] lg:top-[-92px] lg:max-w-[430px]">
              <img
                src={imagenesDeLosDosDijesSrc}
                alt="Dos dijes grabados ACIUM"
                class="h-auto w-full object-contain"
              />
            </div>
          </div>
          </div>
        </section>
      </div>
    </div>
  </article>
</PageLayout>
