---
import Banner from '../ui/Banner.astro';
import EngravingSection from '../organisms/EngravingSection.astro';
import AboutSection from '../ui/AboutSection.astro';
import FeaturedLaunch from '../organisms/FeaturedLaunch.astro';
import SectionDivider from '../atoms/SectionDivider.astro';
import FeaturedWorld from '../organisms/FeaturedWorld.astro';
import WorldFormatsGallerySection from '../organisms/WorldFormatsGallerySection.astro';
import FranchiseSection from '../organisms/FranchiseSection.astro';
import Layout from '../../layouts/Layout.astro';
import type { Locales } from '../../i18n/ui';
import SeparadorOneImage from '../../assets/images/SeparadorOneImage.svg';
import SeparadorTwoImage from '../../assets/images/SeparadorTwoImage.svg';

interface Props {
  lang: Locales;
}

const { lang } = Astro.props;
---

<Layout>
  <Banner />
  <EngravingSection lang={lang} />
  <AboutSection />
  <FeaturedLaunch lang={lang} />
  <SectionDivider img={SeparadorOneImage.src} />
  <FeaturedWorld lang={lang} />
  <WorldFormatsGallerySection lang={lang} />
  <FranchiseSection lang={lang} />
  <SectionDivider img={SeparadorTwoImage.src} />
  </Layout>
