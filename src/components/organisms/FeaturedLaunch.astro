---
import LaunchContent from '../molecules/LaunchContent.astro';
import LaunchMediaPlaceholder from '../molecules/LaunchMediaPlaceholder.astro';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang?: string | undefined | null;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const tagline = t('launch.tagline');
const title = t('launch.title');
const description = t('launch.description');
const ctaText = t('launch.cta');
const ctaHref = '/lanzamientos';
const mediaFallback = t('launch.mediaFallback');
---

<section class="w-full min-h-[600px] flex flex-col lg:flex-row">
  <LaunchMediaPlaceholder fallbackText={mediaFallback} />
  <LaunchContent
    tagline={tagline}
    title={title}
    description={description}
    ctaText={ctaText}
    ctaHref={ctaHref}
  />
</section>
