---
import type { Locales } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import { getLocalizedPageHref, PAGE_ROUTE_ID } from '../../lib/site-navigation';
import NewsroomPlaceholderGallery from '../islands/NewsroomPlaceholderGallery';

interface Props {
  lang?: Locales | string | null;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const ctaHref = getLocalizedPageHref(PAGE_ROUTE_ID.NEWSROOM, lang);
---

<section class="w-full bg-white px-6 py-20 text-black sm:px-10 lg:px-16 xl:px-24 font-avenir">
  <div class="flex w-full flex-col gap-14 lg:flex-row lg:items-center lg:justify-start lg:gap-16">
    <div class="flex w-full max-w-[470px] flex-col items-start gap-8 lg:sticky lg:top-20">
      <h2 class="text-[52px] leading-[0.9] font-[500] uppercase tracking-[-0.05em] text-black">
        {t('newsroom.title')}
      </h2>

      <p class="max-w-[420px] text-[1.05rem] leading-[1.72] text-[#262626] lg:text-[1.12rem]">
        {t('newsroom.description')}
      </p>

      <a
        href={ctaHref}
        class="inline-flex items-center border border-black bg-white px-6 py-3 text-center text-[11px] font-[700] uppercase tracking-[0.32em] text-black transition-colors duration-200 hover:bg-black hover:text-white"
      >
        {t('newsroom.cta')}
      </a>
    </div>

    <div class="w-full min-w-0 lg:max-w-[1040px] lg:flex-1">
      <NewsroomPlaceholderGallery client:load placeholderLabel={t('newsroom.galleryPlaceholder')} />
    </div>
  </div>
</section>

<style>
  @media (min-width: 1024px) {
    .newsroom-card--2 {
      margin-top: 48px;
    }

    .newsroom-card--3 {
      margin-top: 18px;
    }

    .newsroom-card--4 {
      margin-top: 64px;
    }
  }
</style>
