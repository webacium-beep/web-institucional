---
import type { Locales } from '../../i18n/ui';
import { useTranslations } from '../../i18n/utils';
import engravingVideo from '../../assets/DIJE_GIRANDO.webm';

interface Props {
  lang?: Locales | string | null;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const ctaHref = '#';
const mediaFallback = t('engraving.mediaFallback');
---

<section class="w-full bg-white px-6 pt-24 text-black sm:px-10 lg:px-16 lg:pt-20 xl:px-24 font-avenir">
  <div class="mx-auto flex w-full max-w-[1360px] flex-col gap-10 lg:gap-10">
    <h2 class="hidden text-center text-[clamp(1.8rem,3.6vw,3.25rem)] leading-[0.92] font-[500] uppercase tracking-[-0.05em] text-black whitespace-nowrap">
      {t('engraving.hero.title')}
    </h2>

    <div class="flex flex-col gap-6 lg:relative lg:justify-center">
      <div class="relative flex w-full items-center justify-center">
        <div class="w-full lg:w-[60%]">
          <video
            class="h-auto w-full object-contain"
            autoplay
            loop
            muted
            playsinline
            aria-label={mediaFallback}
          >
            <source src={engravingVideo} type="video/webm" />
            {mediaFallback}
          </video>
        </div>
      </div>

      <article class="flex w-full flex-col gap-5 bg-white p-6 sm:p-8 lg:absolute lg:bottom-[580px] lg:left-0 lg:max-w-[430px] lg:p-10">
        <div class="flex flex-col gap-4">
          <span class="text-[16px] font-[300] uppercase tracking-[0.3em] text-[#B7B7B7]">
            {t('engraving.card.eyebrow')}
          </span>

          <h3 class="text-[clamp(2.8rem,4.8vw,4.6rem)] leading-[0.88] font-[500] uppercase tracking-[-0.04em] text-black">
            {t('engraving.card.title')}
          </h3>

          <span class="inline-flex w-fit items-center border border-black px-4 py-2 text-[1.05rem] font-[600] leading-none text-black bg-white">
            {t('engraving.card.badge')}
          </span>
        </div>

        <p class="max-w-[32ch] text-[1.15rem] leading-[1.55] text-[#2A2A2A]">
          {t('engraving.card.description')}
        </p>

        <a
          href={ctaHref}
          class="inline-flex w-fit items-center border border-black bg-white px-5 py-3 text-[11px] font-[700] uppercase tracking-[0.3em] text-black transition-colors duration-200 hover:bg-black hover:text-white"
        >
          {t('engraving.card.cta')}
        </a>
      </article>
    </div>
  </div>
</section>
