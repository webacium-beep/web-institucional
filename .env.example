# ─────────────────────────────────────────────────────────────
# Sanity Content Lake — environment contract
# Copy this file to .env and fill in your project values.
# ─────────────────────────────────────────────────────────────

# Required — Sanity project ID (public, safe to expose in the browser)
PUBLIC_SANITY_PROJECT_ID=8bhbum02

# Required — Sanity dataset name (usually "production")
PUBLIC_SANITY_DATASET=production

# Recommended — Sanity API version in YYYY-MM-DD format.
# A built-in fallback of "2024-04-08" is used when this is absent, but you
# should always pin it explicitly in production so API behaviour is predictable.
SANITY_API_VERSION=2024-04-08

# Optional — Sanity API token for reading private drafts or protected datasets.
# SERVER-ONLY: never prefix with PUBLIC_ — never expose to the browser.
# Leave blank for anonymous public reads; only required for authenticated queries.
# SANITY_API_TOKEN=
